		picture plus_minus;
		plus_minus := plus_minus_raw shifted (-(llcorner plus_minus_raw)-(urcorner plus_minus_raw - llcorner plus_minus_raw)/2) scaled (2u / 3 / ((xpart urcorner plus_minus_raw) - (xpart llcorner plus_minus_raw)));

		def p_u_plus_minus(expr pos, theta, sc, al) = 
			T := identity shifted pos;
			thdraw plus_minus withcolor black;
		enddef;

		def p_u_raft_cone (expr pos,theta,sc,al)=
			U:=(.3u,.4u);
			T:=identity aligned al rotated theta scaled sc shifted pos;
			pickup PenC;
			thdraw (-.3u,-.4u)--(0,.4u)--(.3u,-.4u);
		enddef; 

		def p_u_stalagmite_stalactite (expr pos,theta,sc,al)=
			U:=(.15u, .4u);
			T:=identity aligned al rotated theta scaled sc shifted pos;
			pickup PenC;
			thdraw (-.15u,.4u) -- (0,.2u) -- (0,.1u);
			thdraw (0,-.1u) -- (0,-.2u) -- (-.15u,-.4u);
			thdraw (0,-.2u) -- (.15u,-.4u);
			thdraw (0,.2u) -- (.15u,.4u);
		enddef;

		def p_u_stalagmites_stalactites (expr pos,theta,sc,al) =
			U:=(.3u, .2u);
			T:=identity aligned al rotated theta scaled sc shifted pos;
			pickup PenC;
			for i=-1 upto 1:
				T:=identity aligned al rotated theta scaled (sc * 0.7) shifted (pos + (i * .3u, 0));
				thdraw (-.15u,.4u) -- (0,.2u) -- (0,.1u);
				thdraw (0,-.1u) -- (0,-.2u) -- (-.15u,-.4u);
				thdraw (0,-.2u) -- (.15u,-.4u);
				thdraw (0,.2u) -- (.15u,.4u);
			endfor;
		enddef;
		
		def p_u_flying_saucer_stalactite(expr pos,theta,sc,al) =
		  U:=(.15u, .4u);
		  T:=identity aligned al rotated theta scaled sc shifted pos;
		  pickup PenC;
		  thdraw (0,-.4u) -- (0,.15u) -- (-.15u,.4u);
		  thdraw (0,.15u) -- (.15u,.4u);
		  thdraw (-.15u,-.1u) -- (.15u,-.1u);
		enddef;
		
		def p_u_flying_saucer_stalagmite(expr pos,theta,sc,al) =
		  U:=(.15u, .4u);
		  T:=identity aligned al rotated theta scaled sc shifted pos;
		  pickup PenC;
			thdraw (0,.4u) -- (0,-.15u) -- (-.15u,-.4u);
			thdraw (0,-.15u) -- (.15u,-.4u);
		  thdraw (-.15u,.1u) -- (.15u,.1u);
		enddef;
		
		def p_u_flying_saucer_column(expr pos,theta,sc,al) =
		  U:=(.15u, .4u);
		  T:=identity aligned al rotated theta scaled sc shifted pos;
		  pickup PenC;
			thdraw (-.15u,.4u) -- (0,.15u) -- (0,-.15u) -- (-.15u,-.4u);
			thdraw (0,-.15u) -- (.15u,-.4u);
			thdraw (0,.15u) -- (.15u,.4u);
		  thdraw (-.15u,0) -- (.15u,0);
		enddef;
		
		def p_u_flying_saucers_stalactites(expr pos,theta,sc,al) =
			U:=(.3u, .2u);
			T:=identity aligned al rotated theta scaled sc shifted pos;
			pickup PenC;
			for i=-1 upto 1:
				T:=identity aligned al rotated theta scaled (sc * 0.7) shifted (pos + (i * .3u, 0));
				thdraw (0,-.4u) -- (0,.15u) -- (-.15u,.4u);
				thdraw (0,.15u) -- (.15u,.4u);
				thdraw (-.15u,-.1u) -- (.15u,-.1u);
			endfor;
		enddef;
		
		def p_u_flying_saucers_stalagmites(expr pos,theta,sc,al) =
			U:=(.3u, .2u);
			T:=identity aligned al rotated theta scaled sc shifted pos;
			pickup PenC;
			for i=-1 upto 1:
				T:=identity aligned al rotated theta scaled (sc * 0.7) shifted (pos + (i * .3u, 0));
				thdraw (0,.4u) -- (0,-.15u) -- (-.15u,-.4u);
				thdraw (0,-.15u) -- (.15u,-.4u);
				thdraw (-.15u,.1u) -- (.15u,.1u);
			endfor;
		enddef;
		
		def p_u_flying_saucers_columns(expr pos,theta,sc,al) =
			U:=(.3u, .2u);
			T:=identity aligned al rotated theta scaled sc shifted pos;
			pickup PenC;
			for i=-1 upto 1:
				T:=identity aligned al rotated theta scaled (sc * 0.7) shifted (pos + (i * .3u, 0));
				thdraw (-.15u,.4u) -- (0,.15u) -- (0,-.15u) -- (-.15u,-.4u);
				thdraw (0,-.15u) -- (.15u,-.4u);
				thdraw (0,.15u) -- (.15u,.4u);
				thdraw (-.15u,0) -- (.15u,0);
			endfor;
		enddef;
		
		def l_u_rimstonedam (expr P) =
			cas := 0;
			distance := arclength P;
			mystep := adjust_step(distance, 0.9u);
			pickup PenC;
			forever:
				t  := arctime (cas + mystep/2) of P;
				T := identity rotated angle(thdir(P,t)) scaled 0.7 shifted (point t of P);
				thdraw (-.45u,.2u){dir -80}..{dir -50}(-.15u,0){dir 30}..{dir -30}(.15u,.1u){dir -50}..{dir 70}(.45u,.2u);
				cas := cas + mystep;
				exitif cas > distance - (2*mystep/3); % for rounding errors
			endfor;
		enddef;
		
		def l_u_rimstonepool (expr P) =
			cas := 0;
			distance := arclength P;
			mystep := adjust_step(distance, 0.9u);
			pickup PenC;
			forever:
				t  := arctime (cas + mystep/2) of P;
				T := identity rotated angle(thdir(P,t)) scaled 0.7 shifted (point t of P);
				p := (-.45u,.2u){dir -80}..{dir -50}(-.15u,-.1u){dir 30}..{dir -30}(.15u,.1u){dir -50}..{dir 70}(.45u,.2u);
				thfill buildcycle(p,((.5u,.15u)--(-.5u,.15u)));
				thdraw p;
				cas := cas + mystep;
				exitif cas > distance - (2*mystep/3); % for rounding errors
			endfor;
		enddef;

	endcode
	
endlayout

