			fill f--le--pointFace--n--pointFace--re--cycle;
			fill tlb;
			fill trb;
			fill blb;
			fill brb;
		);
		picture danger;
		danger := danger_raw shifted (-(llcorner danger_raw)-(urcorner danger_raw - llcorner danger_raw)/2) scaled (u / ((xpart urcorner danger_raw) - (xpart llcorner danger_raw)));

		def p_u_danger(expr pos, theta, sc, al) = 
			T := identity shifted pos;
			%thfill bb_danger_raw withcolor (0.3, 0.2, 0.1);
			%thdraw (llcorner bb_danger_raw) withpen pencircle scaled 4bp withcolor black;
			%thdraw thelabel.llft("llcorner bb_danger_raw (" & decimal(xpart llcorner bb_danger_raw) & ", " & decimal(ypart llcorner bb_danger_raw) & ")", llcorner bb_danger_raw);
			%thdraw (lrcorner bb_danger_raw) withpen pencircle scaled 4bp withcolor black;
			%thdraw thelabel.lrt("lrcorner bb_danger_raw (" & decimal(xpart lrcorner bb_danger_raw) & ", " & decimal(ypart lrcorner bb_danger_raw) & ")", lrcorner bb_danger_raw);
			%thdraw (ulcorner bb_danger_raw) withpen pencircle scaled 4bp withcolor black;
			%thdraw thelabel.ulft("ulcorner bb_danger_raw (" & decimal(xpart ulcorner bb_danger_raw) & ", " & decimal(ypart ulcorner bb_danger_raw) & ")", ulcorner bb_danger_raw);
			%thdraw (urcorner bb_danger_raw) withpen pencircle scaled 4bp withcolor black;
			%thdraw thelabel.urt("urcorner bb_danger_raw (" & decimal(xpart urcorner bb_danger_raw) & ", " & decimal(ypart urcorner bb_danger_raw) & ")", urcorner bb_danger_raw);
			%thdraw danger_raw withcolor (0.1,0.2,0.3);
			%thfill bbox danger withcolor green;
			%thdraw (llcorner bb_danger) withpen pencircle scaled 4bp withcolor black;
			%thdraw thelabel.llft("llcorner bb_danger (" & decimal(xpart llcorner bb_danger) & ", " & decimal(ypart llcorner bb_danger) & ")", llcorner bb_danger);
			%thdraw (lrcorner bb_danger) withpen pencircle scaled 4bp withcolor black;
			%thdraw thelabel.lrt("lrcorner bb_danger (" & decimal(xpart lrcorner bb_danger) & ", " & decimal(ypart lrcorner bb_danger) & ")", lrcorner bb_danger);
			%thdraw (ulcorner bb_danger) withpen pencircle scaled 4bp withcolor black;
			%thdraw thelabel.ulft("ulcorner bb_danger (" & decimal(xpart ulcorner bb_danger) & ", " & decimal(ypart ulcorner bb_danger) & ")", ulcorner bb_danger);
			%thdraw (urcorner bb_danger) withpen pencircle scaled 4bp withcolor black;
			%thdraw thelabel.urt("urcorner bb_danger (" & decimal(xpart urcorner bb_danger) & ", " & decimal(ypart urcorner bb_danger) & ")", urcorner bb_danger);
			thdraw danger withcolor red;
			%thdraw (0,0) withpen pencircle scaled 4bp withcolor blue;
		enddef;

		picture minus_raw;
	 	minus_raw := image(
			fill (294.660004,411.578003)--(307.644989,411.578003)--(307.644989,407.625000)
				--(294.660004,407.625000)--cycle;
			pickup pencircle scaled 1.285130bp;
			draw (314.710999,409.601990)..controls (314.710999,402.113007) and (308.640991,396.042999)..(301.152008,396.042999)
				..controls (293.664001,396.042999) and (287.593994,402.113007)..(287.593994,409.601990)
				..controls (287.593994,417.089996) and (293.664001,423.160004)..(301.152008,423.160004)
				..controls (308.640991,423.160004) and (314.710999,417.089996)..(314.710999,409.601990)
				--cycle;
		);
		picture minus;
		minus := minus_raw shifted (-(llcorner minus_raw)-(urcorner minus_raw - llcorner minus_raw)/2) scaled (2u / 3 / ((xpart urcorner minus_raw) - (xpart llcorner minus_raw)));

		def p_u_minus(expr pos, theta, sc, al) = 
			T := identity shifted pos;
			thdraw minus withcolor black;
		enddef;

		picture plus_raw;
	 	plus_raw := image(
			fill (394.687988,411.277008)--(394.687988,403.121002)--(402.843994,403.121002)
				--(402.843994,400.621002)--(394.687988,400.621002)--(394.687988,392.464996)
				--(392.234009,392.464996)--(392.234009,400.621002)--(384.062988,400.621002)
				--(384.062988,403.121002)--(392.234009,403.121002)--(392.234009,411.277008)
				--cycle;
			fill (394.687988,411.277008)--cycle;
			pickup pencircle scaled 0.750000bp;
			draw (394.687988,411.277008)--(394.687988,403.121002)--(402.843994,403.121002)
				--(402.843994,400.621002)--(394.687988,400.621002)--(394.687988,392.464996)
				--(392.234009,392.464996)--(392.234009,400.621002)--(384.062988,400.621002)
