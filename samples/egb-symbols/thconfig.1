encoding  utf-8
source map.th2

layout m

code tex-map
\legendcontent={%
  \hsize=\legendwidth
  \color[0 0 0]\the\legendtextcolor 
  \formattedlegend
  \color[0 0 0]
}

endlayout

#language pt

input extra_points.th
input extra_lines.th
input extra_areas.th

export map -o map2.pdf -layout m -layout extra_points -layout extra_lines -layout extra_areas -layout-map-header 0 0 nw -layout-legend on
