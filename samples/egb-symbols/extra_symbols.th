		picture bone;
		bone := bone_raw shifted (-(llcorner bone_raw)-(urcorner bone_raw - llcorner bone_raw)/2) scaled (u / ((xpart urcorner bone_raw) - (xpart llcorner bone_raw)));

		def p_u_bone(expr pos, theta, sc, al) = 
			T:=identity aligned al rotated theta scaled sc shifted pos;
			thdraw bone withcolor black;
		enddef;

		def p_u_curtains(expr pos, theta, sc, al) = 
			U:=(.3u, .8u);
			pickup PenC;
			for i=-1 upto 1:
				T:=identity aligned al rotated theta scaled (sc * 0.7) shifted (pos + (i * .3u, abs(i) * .15u));
				thdraw (-.15u,.4u)--(0,.15u)--(.15u,.4u);
				thdraw (0,.15u)--(0,0){dir 180}..(-.12u,-.11u)..{dir 0}(0,-.22u)--(0,-.4u);
			endfor;
		enddef;

		def p_u_helictites(expr pos,theta,sc,al) =
			U:=(.4u,.8u);
			pickup PenC;
			for i=-1 upto 1:
				if i < 0:
					T:=identity aligned al rotated theta scaled (sc * 0.7) shifted (pos + (i * .45u, abs(i) * .15u));
				else:
					T:=identity aligned al rotated theta scaled (sc * 0.7) shifted (pos + (i * .3u, abs(i) * .15u));
				fi;
				thdraw (0,.4u)--(0,-.4u);
				p := (-.2u,.4u)---(-.2u,.1u){down}..{dir -10}(-.1u,0.02u)---origin;
				thdraw p;
				thdraw p reflectedabout (origin,(0,u)) reflectedabout (origin,(u,0));
			endfor;
		enddef;

		def p_u_raft_cone (expr pos,theta,sc,al)=
			U:=(.3u,.4u);
			T:=identity aligned al rotated theta scaled sc shifted pos;
			pickup PenC;
			thdraw (-.3u,-.4u)--(0,.4u)--(.3u,-.4u);
		enddef; 

		def p_u_stalagmite_stalactite (expr pos,theta,sc,al)=
			U:=(.15u, .4u);
			T:=identity aligned al rotated theta scaled sc shifted pos;
			pickup PenC;
			thdraw (-.15u,.4u) -- (0,.2u) -- (0,.1u);
			thdraw (0,-.1u) -- (0,-.2u) -- (-.15u,-.4u);
			thdraw (0,-.2u) -- (.15u,-.4u);
			thdraw (0,.2u) -- (.15u,.4u);
		enddef;

		def p_u_stalagmites_stalactites (expr pos,theta,sc,al) =
			U:=(.3u, .8u);
			pickup PenC;
			for i=-1 upto 1:
				T:=identity aligned al rotated theta scaled (sc * 0.7) shifted (pos + (i * .3u, abs(i) * .15u));
				thdraw (-.15u,.4u) -- (0,.2u) -- (0,.1u);
				thdraw (0,-.1u) -- (0,-.2u) -- (-.15u,-.4u);
				thdraw (0,-.2u) -- (.15u,-.4u);
				thdraw (0,.2u) -- (.15u,.4u);
			endfor;
		enddef;

		def p_u_disc_stalactite(expr pos,theta,sc,al) =
			U:=(.15u, .4u);
			T:=identity aligned al rotated theta scaled sc shifted pos;
			pickup PenC;
			thdraw (0,-.4u) -- (0,.15u) -- (-.15u,.4u);
			thdraw (0,.15u) -- (.15u,.4u);
			thdraw (-.15u,-.1u) -- (.15u,-.1u);
		enddef;
		
		def p_u_disc_stalagmite(expr pos,theta,sc,al) =
			U:=(.15u, .4u);
			T:=identity aligned al rotated theta scaled sc shifted pos;
			pickup PenC;
			thdraw (0,.4u) -- (0,-.15u) -- (-.15u,-.4u);
			thdraw (0,-.15u) -- (.15u,-.4u);
			thdraw (-.15u,.1u) -- (.15u,.1u);
		enddef;
		
		def p_u_disc_pillar(expr pos,theta,sc,al) =
			U:=(.15u, .4u);
			T:=identity aligned al rotated theta scaled sc shifted pos;
			pickup PenC;
			thdraw (-.15u,.4u) -- (0,.15u) -- (0,-.15u) -- (-.15u,-.4u);
			thdraw (0,-.15u) -- (.15u,-.4u);
			thdraw (0,.15u) -- (.15u,.4u);
			thdraw (-.15u,0) -- (.15u,0);
		enddef;
		
		def p_u_discs_stalactites(expr pos,theta,sc,al) =
			U:=(.3u, .8u);
			pickup PenC;
			for i=-1 upto 1:
				T:=identity aligned al rotated theta scaled (sc * 0.7) shifted (pos + (i * .3u, abs(i) * .15u));
				thdraw (0,-.4u) -- (0,.15u) -- (-.15u,.4u);
				thdraw (0,.15u) -- (.15u,.4u);
				thdraw (-.15u,-.1u) -- (.15u,-.1u);
			endfor;
		enddef;

		def p_u_discs_stalagmites(expr pos,theta,sc,al) =
			U:=(.3u, .8u);
			pickup PenC;
			for i=-1 upto 1:
				T:=identity aligned al rotated theta scaled (sc * 0.7) shifted (pos + (i * .3u, abs(i) * .15u));
				thdraw (0,.4u) -- (0,-.15u) -- (-.15u,-.4u);
				thdraw (0,-.15u) -- (.15u,-.4u);
				thdraw (-.15u,.1u) -- (.15u,.1u);
			endfor;
		enddef;

		def p_u_discs_pillars(expr pos,theta,sc,al) =
			U:=(.3u, .8u);
			pickup PenC;
			for i=-1 upto 1:
				T:=identity aligned al rotated theta scaled (sc * 0.7) shifted (pos + (i * .3u, abs(i) * .15u));
				thdraw (-.15u,.4u) -- (0,.15u) -- (0,-.15u) -- (-.15u,-.4u);
				thdraw (0,-.15u) -- (.15u,-.4u);
				thdraw (0,.15u) -- (.15u,.4u);
				thdraw (-.15u,0) -- (.15u,0);
			endfor;
		enddef;

		def l_u_rimstonedam (expr P) =
			cas := 0;
			distance := arclength P;
			mystep := adjust_step(distance, 0.9u);
			pickup PenC;
			forever:
				t  := arctime (cas + mystep/2) of P;
				T := identity rotated angle(thdir(P,t)) scaled 0.7 shifted (point t of P);
				thdraw (-.45u,.2u){dir -80}..{dir -50}(-.15u,0){dir 30}..{dir -30}(.15u,.1u){dir -50}..{dir 70}(.45u,.2u);
				cas := cas + mystep;
				exitif cas > distance - (2*mystep/3); % for rounding errors
			endfor;
		enddef;
		
		def l_u_rimstonepool (expr P) =
			cas := 0;
			distance := arclength P;
			mystep := adjust_step(distance, 0.9u);
			pickup PenC;
			forever:
				t  := arctime (cas + mystep/2) of P;
				T := identity rotated angle(thdir(P,t)) scaled 0.7 shifted (point t of P);
				p := (-.45u,.2u){dir -80}..{dir -50}(-.15u,-.1u){dir 30}..{dir -30}(.15u,.1u){dir -50}..{dir 70}(.45u,.2u);
				thfill buildcycle(p,((.5u,.15u)--(-.5u,.15u)));
				thdraw p;
				cas := cas + mystep;
				exitif cas > distance - (2*mystep/3); % for rounding errors
			endfor;
		enddef;

	endcode
	
endlayout

